/* app.wxss - 全局样式 */
page {
  background: linear-gradient(180deg, #FFF5F0 0%, #F8F8F8 400rpx);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 100vh;
}

.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 102, 51, 0.08);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  padding: 16rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 102, 51, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: #FF6633;
  border-radius: 48rpx;
  border: 2rpx solid #FF6633;
  font-size: 28rpx;
  padding: 12rpx 32rpx;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
}

.empty-state text {
  font-size: 28rpx;
}

/* 登录遮罩 */
.login-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.login-modal {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx 40rpx;
  width: 600rpx;
  text-align: center;
}

.login-modal-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.login-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.login-modal-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-modal-phone {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 30rpx;
}

.login-modal-phone image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.login-modal-phone input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.login-modal-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  padding: 18rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 102, 51, 0.3);
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn[disabled] {
  background: #ddd;
  box-shadow: none;
}

.login-modal-close {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
  background: transparent;
  border: none;
  padding: 12rpx 0;
}

.login-modal-close::after {
  border: none;
}
