/* pages/create-challenge/create-challenge.wxss */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-option {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: #F8F8F8;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.icon-option.selected {
  border-color: #FF6633;
  background: linear-gradient(135deg, #FFF5F0, #FFE8D6);
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.15);
  transform: scale(1.05);
}

.input-field {
  width: 100%;
  padding: 18rpx 20rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.textarea-field {
  width: 100%;
  height: 160rpx;
  padding: 18rpx 20rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.radio-group {
  display: flex;
  gap: 24rpx;
}

.radio {
  padding: 12rpx 32rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.radio.selected {
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.3);
}

.hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 40rpx;
  width: 100%;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  border-radius: 48rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  padding: 18rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(255, 102, 51, 0.35);
}

.submit-btn::after {
  border: none;
}
