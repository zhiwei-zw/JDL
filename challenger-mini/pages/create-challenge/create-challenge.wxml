<!--pages/create-challenge/create-challenge.wxml-->
<view class="container">
  <form bindsubmit="onSubmit">
    <!-- 挑战图标选择 -->
    <view class="card">
      <view class="section-title">选择图标</view>
      <view class="icon-grid">
        <block wx:for="{{iconOptions}}" wx:key="*this">
          <view class="icon-option {{selectedIcon === item ? 'selected' : ''}}"
                bindtap="selectIcon" data-icon="{{item}}">
            <text>{{item}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 挑战名称 -->
    <view class="card">
      <view class="section-title">挑战名称</view>
      <input class="input-field" name="title" placeholder="例如：早起打卡30天" maxlength="30" value="{{title}}" bindinput="onInputTitle" />
    </view>

    <!-- 挑战描述 -->
    <view class="card">
      <view class="section-title">挑战描述（选填）</view>
      <textarea class="textarea-field" name="desc" placeholder="描述一下这个挑战..." maxlength="100" value="{{desc}}" bindinput="onInputDesc" />
    </view>

    <!-- 挑战天数 -->
    <view class="card">
      <view class="section-title">挑战天数</view>
      <picker mode="selector" range="{{dayOptions}}" value="{{selectedDayIndex}}" bindchange="onDayChange">
        <view class="picker-value">
          <text>坚持 {{dayOptions[selectedDayIndex] || 7}} 天</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 公开/私密 -->
    <view class="card">
      <view class="section-title">可见性</view>
      <view class="radio-group">
        <view class="radio {{isPublic ? 'selected' : ''}}" bindtap="togglePublic">
          <text>公开</text>
        </view>
        <view class="radio {{!isPublic ? 'selected' : ''}}" bindtap="togglePublic">
          <text>私密</text>
        </view>
      </view>
      <view class="hint">公开挑战会被其他人看到，私密只有你邀请的人能看到</view>
    </view>

    <!-- 提交按钮 -->
    <button class="btn-primary submit-btn" formType="submit" type="primary">创建挑战</button>
  </form>
</view>
