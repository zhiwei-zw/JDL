/* pages/challenge-detail/challenge-detail.wxss */
.challenge-header {
  text-align: center;
  padding: 48rpx 24rpx 36rpx;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
}

.header-icon {
  font-size: 88rpx;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  color: #fff;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 28rpx;
}

.header-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  margin: 0 20rpx;
  color: rgba(255, 255, 255, 0.3);
}

.header-join-btn,
.header-checkin {
  margin-top: 10rpx;
}

.header-checked {
  margin-top: 10rpx;
}

.checked-badge {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: inline-block;
}

.btn-primary {
  background: #fff;
  color: #FF6633;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.btn-primary::after {
  border: none;
}

/* 进度 */
.progress-section {
  padding: 28rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
}

.progress-bar-container {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6633, #FF8C42);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 28rpx;
}

/* 打卡日历 */
.checkin-calendar {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.day-box {
  width: calc(10% - 10rpx);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #ccc;
  position: relative;
}

.day-box.checked {
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(255, 102, 51, 0.2);
}

.day-box.checked text {
  font-weight: 600;
}

.day-box::after {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #FF6633;
  margin-top: 2rpx;
  opacity: 0.3;
}

.day-box.checked::after {
  background: #fff;
  opacity: 0.6;
}

/* 成员列表 */
.member-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.member-days {
  font-size: 22rpx;
  color: #999;
}

.member-badge {
  font-size: 28rpx;
}

.empty-hint {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 20rpx 0;
}
