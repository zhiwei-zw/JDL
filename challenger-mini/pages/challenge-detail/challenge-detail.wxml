<!--pages/challenge-detail/challenge-detail.wxml-->
<view class="container">
  <!-- 挑战信息 -->
  <view class="card challenge-header">
    <view class="header-icon">{{challenge.icon || '🎯'}}</view>
    <text class="header-title">{{challenge.title}}</text>
    <text class="header-desc" wx:if="{{challenge.desc}}">{{challenge.desc}}</text>
    <view class="header-stats">
      <view class="stat-item">
        <text class="stat-num">{{challenge.joinCount || 0}}</text>
        <text class="stat-label">参与者</text>
      </view>
      <view class="stat-divider">|</view>
      <view class="stat-item">
        <text class="stat-num">{{challenge.dailyLimit}}天</text>
        <text class="stat-label">挑战周期</text>
      </view>
      <view class="stat-divider">|</view>
      <view class="stat-item" wx:if="{{challenge.isCreator}}">
        <text class="stat-label">发起人</text>
      </view>
    </view>
    <view class="header-join-btn" wx:if="{{!isJoined}}">
      <button class="btn-primary" bindtap="joinChallenge">加入挑战</button>
    </view>
    <view class="header-checkin" wx:elif="{{!hasCheckedIn}}">
      <button class="btn-primary" bindtap="doCheckin">打卡</button>
    </view>
    <view class="header-checked" wx:elif="{{hasCheckedIn}}">
      <view class="checked-badge">✅ 今日已打卡</view>
    </view>
  </view>

  <!-- 我的进度 -->
  <view class="card progress-section" wx:if="{{isJoined}}">
    <view class="section-title">我的进度</view>
    <view class="progress-bar-container">
      <view class="progress-bar" style="width: {{progressPercent}}%">
        <view class="progress-fill"></view>
      </view>
    </view>
    <view class="progress-text">
      <text>第 {{currentDay}} / {{challenge.dailyLimit}} 天</text>
      <text>连续 {{streakDays}} 天</text>
    </view>
    <!-- 打卡日历 -->
    <view class="checkin-calendar">
      <block wx:for="{{challenge.dailyLimit}}" wx:key="*this">
        <view class="day-box {{checkedDays.includes(index + 1) ? 'checked' : ''}}">
          <text>{{index + 1}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 参与者列表 -->
  <view class="card">
    <view class="section-title">参与成员 ({{members.length}})</view>
    <block wx:for="{{members}}" wx:key="_id">
      <view class="member-item">
        <image class="member-avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="member-info">
          <text class="member-name">{{item.nickname}}</text>
          <text class="member-days">已完成 {{item.totalDays || 0}} 天</text>
        </view>
        <view class="member-badge" wx:if="{{item.isCreator}}">
          <text>👑</text>
        </view>
      </view>
    </block>
    <view wx:if="{{members.length === 0}}" class="empty-hint">暂无成员</view>
  </view>
</view>
