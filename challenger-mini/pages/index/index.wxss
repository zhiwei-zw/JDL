/* pages/index/index.wxss */
.page-header {
  padding: 20rpx 0 10rpx;
  margin-bottom: 10rpx;
}

.page-header-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2rpx;
}

.page-header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-bar input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.category-tabs {
  white-space: nowrap;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.category-tabs .tab {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 10rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(6rpx);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.category-tabs .tab.active {
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.3);
}

/* 挑战卡片 */
.challenge-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  transition: transform 0.15s;
}

.challenge-card:active {
  transform: scale(0.98);
}

.challenge-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  width: 90rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF5F0, #FFE8D6);
  border-radius: 24rpx;
  flex-shrink: 0;
}

.challenge-info {
  flex: 1;
  min-width: 0;
}

.challenge-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.challenge-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.challenge-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.meta-divider {
  margin: 0 10rpx;
  color: #ddd;
}

.meta-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  background: #FFF7E6;
  color: #FF8C42;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-left: 8rpx;
}

/* 悬浮创建按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 51, 0.4);
  z-index: 10;
  transition: transform 0.2s;
}

.fab-button:active {
  transform: scale(0.9);
}

.fab-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}
