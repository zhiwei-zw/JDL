<!--pages/index/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-header-title">打卡挑战</text>
    <text class="page-header-subtitle">坚持每一天，遇见更好的自己</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <icon type="search" size="14" color="#999" />
    <input placeholder="搜索挑战..." bindinput="onSearchInput" value="{{searchKeyword}}" />
    <icon wx:if="{{searchKeyword}}" type='clear' size="14" color="#999" bindtap="clearSearch" />
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-tabs" scroll-x>
    <view class="tab {{activeCategory === '' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="">全部</view>
    <view class="tab {{activeCategory === 'self' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="self">自律</view>
    <view class="tab {{activeCategory === 'health' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="health">健康</view>
    <view class="tab {{activeCategory === 'study' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="study">学习</view>
    <view class="tab {{activeCategory === 'work' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="work">工作</view>
    <view class="tab {{activeCategory === 'creative' ? 'active' : ''}}" bindtap="onSwitchCategory" data-category="creative">创作</view>
  </scroll-view>

  <!-- 挑战列表 -->
  <view wx:if="{{!loading && challenges.length > 0}}" class="challenge-list">
    <block wx:for="{{challenges}}" wx:key="_id">
      <view class="card challenge-card" bindtap="goToDetail" data-challenge="{{item}}">
        <view class="challenge-icon">{{item.icon}}</view>
        <view class="challenge-info">
          <text class="challenge-title">{{item.title}}</text>
          <text class="challenge-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
          <view class="challenge-meta">
            <text class="meta-item">{{item.joinCount}} 人参与</text>
            <text class="meta-divider">·</text>
            <text class="meta-item">Day {{item.dailyLimit}}</text>
            <text wx:if="{{!item.isPublic}}" class="meta-tag">私密</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载中 -->
  <view wx:elif="{{loading}}" class="empty-state">
    <view class="loading-spinner">加载中...</view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <text class="empty-text">暂无挑战</text>
    <text class="empty-hint">点击右上角 + 号创建第一个挑战</text>
  </view>

  <!-- 创建挑战按钮 -->
  <view class="fab-button" bindtap="goToCreate">
    <text class="fab-icon">+</text>
  </view>
</view>
