/* pages/profile/profile.wxss */
.user-header {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #FF6633, #FF8C42);
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-btn {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.login-btn::after {
  border: none;
}

/* 登录弹窗中的手机号输入 */
.login-modal-phone {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 30rpx;
}

.login-modal-phone image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.phone-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.login-modal-phone input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  margin-top: -20rpx;
  border-radius: 20rpx 20rpx 0 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6633;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 挑战列表项 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.challenge-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.challenge-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF5F0, #FFE8D6);
  border-radius: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta,
.item-days {
  font-size: 22rpx;
  color: #999;
}

.empty-hint {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 20rpx 0;
}
